# Monorepo env: copy this file to `.env.local` at the **repo root** (not under apps/).
# Both apps load it in dev via `dotenv -e ../../.env.local` in apps/*/package.json.
# This is intentional — studio and workspace share one Supabase project.
#
# Per-app overrides (optional): apps/studio/.env.local or apps/workspace/.env.local
# if you later need different keys; you would also wire dotenv paths in that app's scripts.
#
# Production builds/deploy: set VITE_* in CI or `wrangler secret put` per worker;
# `npm run build` does not run dotenv-cli (only `npm run dev` does).

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional portal hostnames (server + client via import.meta.env / process.env)
SAAS_HOST=forestack.dev
TENANT_HOST=forestack.space
# Dev tenant URLs use `{slug}.${DEV_HOST}` (see packages/shared/src/lib/utils/domain-type.ts).
# Studio dev: localhost:3000. Workspace dev: set DEV_HOST=localhost:3001 for `{slug}.localhost:3001`.
DEV_HOST=localhost:3000

# --- WorkOS (workspace tenant SSO only; studio stays on Supabase Auth) ---
# See docs/roadmap/workos-workspace-implementation-plan.md
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# WORKOS_AUTH_DOMAIN=api.workos.com
# Optional: override callback when testing a single tenant locally
# WORKOS_REDIRECT_URI=http://acme.localhost:3001/auth/workos-callback
# Set to true once credentials + Supabase Third-Party Auth are registered
# WORKOS_AUTH_ENABLED=false
# Optional: WorkOS org id for dev SSO before app_organization_identity_providers row exists
# WORKOS_DEV_ORGANIZATION_ID=org_01H...
#
# Workspace dev runs inside the Cloudflare Workers runtime. The dev script sets
# CLOUDFLARE_INCLUDE_PROCESS_ENV=true so vars from this file (via dotenv-cli)
# reach server functions. Production: wrangler secret put WORKOS_API_KEY, etc.
